class falcons:
    def __init__(self,x,y):
        self.x=x  #就是通过self把外部属性x绑定给x
        self.y=y
    def add(self):
        return self.x+self.y
    def mul(self):
        return self.x*self.y

niko=falcons(2,2)
print(niko.add())
monesy=falcons(3,2)
print(monesy.mul())
#result：
4
6
#也就是说，可以通过__init__(self,x,y):的方式帮你直接绑定属性给实例，而不用自己手动改
class falcons:
    def __init__(self,x,y):
        self.x=x
        self.y=y
    def add(self):
        return self.x+self.y
    def mul(self):
        return self.x*self.y

class spirit(falcons):
    def __init__(self,x,y,z):
        falcons.__init__(self,x,y)   #通过.__init__的方式可以直接省去写self.x=x，但是后来又学了super函数
#上面的代码可以改为：super().__init__(x,y)   注意这里的（）里只能填两个字符串或者变量或者数字，但是不能填3个或者2个，因为父类falcons里有两个形参
        self.z=z                     #在类falcons里没有绑定的实例仍然要绑定
    def add(self):
        return falcons.add(self)+self.z  #直接调用父类falcons，千万不要忘了self
    def mul(self):
        return falcons.mul(self)*self.z

donk=spirit(7,1,3)
print(donk.add())
print(donk.mul())
