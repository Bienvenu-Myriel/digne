#由于类的继承会出现钻石继承，所以需要使用super函数
#下面是钻石继承的典型案例：
class moon:
    def __init__(self):
        print("小乐")

class sun(moon):
    def __init__(self):
        moon.__init__(self)
        print("小辉")

class star(moon):
    def __init__(self):
        moon.__init__(self)
        print("廖总")

class cloud(sun,star):
    def __init__(self):
        sun.__init__(self)
        star.__init__(self)
        print(" 牢猪")

faker=cloud()
print(faker)
#result：小乐
小辉
小乐
廖总
 牢猪
#里面小乐被打印了两遍，因为cloud同时继承了两个父类，而两个父类又继承了一个父类，所有最开始的父类被打印了两次
#要解决这个难点就是通过把上面麻烦的调用类的代码换成super().__init__()
class moon:
    def __init__(self):
        print("小乐")

class sun(moon):
    def __init__(self):
        super().__init__()  #千万注意绝对不能在.__init__()里的()里写self
        print("小辉")

class star(moon):
    def __init__(self):
        super().__init__()
        print("廖总")

class cloud(sun,star):
    def __init__(self):
        super().__init__() #注意之前要调用两个父类的代码直接被优化成一个了
        print(" 牢猪")

faker=cloud()
print(faker)
#result: 小乐
廖总
小辉
 牢猪

#super()函数严重依赖mro，可以通过在类的后面加上.mro来查看mro顺序
#比如moon.mro或者cloud.mro

