<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>今晚吃什么</title>
 <link rel="icon" href="gemini.png" type="image/x-icon">
</head>
<body>
  <form action="https://www.youtube.com/results" method="get" target="_blank">
    <!-- get和post和python爬虫里一样，在网址的com后面加上/和对应网址？前的内容，youtube是results -->
     <button>搜索</button>
     <!-- button就是按钮也可以是input 把type里的类型改成submit或者别的什么，比如password --> 
     <input type="text" name="search_query">

      <!-- name是用来识别变量名的,网址栏会在？后显示变量名=我们在text里输入的内容（youtube的？后面是search_query） -->


      <br>

  </form>

   <form action="" method="post" target="_blank">
    <!-- 一般密码账号这种都要通过post请求 -->
    请输入账号：<input type="usename" name="" >
   <br>
    请输入密码：<input type="password" name="" id="">
    <br>
    <input type="submit" value="登录">
    <!-- input的type里的submit和button的效果一样，但是名字要通过value来更改 -->
    <br>
    性别：
    <label for="male">男</label>
    <input type="radio" name="sex" id="male" value="male">
    <label for="female">女</label>
    <!-- 当我们点击汉字男或者女的时候，通过label可以直接帮我们点击圆点，注意for要和id一致一致 -->
    
    <input type="radio" name="sex" id="female" value="female">


   </form>

</body>
</html>
