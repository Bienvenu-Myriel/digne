<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>falcons</title>
    <link rel="icon" href="gemini.png" type="image/png">
    <style>
        /* 相邻兄弟选择器:选中下一个class */
        div.monesy+div{
            color: red;
        }
        /* 通用兄弟选择器 ，选中下面所有class*/
        div.monesy~div{
            background-color: green;
        }
    </style>
</head>
<body>
    
    <div class="niko">
        <div class="monesy">1.27rating</div>
        <div class="kyousuke">1.20rating</div>
        <div class="donk">1.42rating</div>
    </div>

</body>
</html>
