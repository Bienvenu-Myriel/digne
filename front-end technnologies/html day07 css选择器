<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>zeus</title>
     <link rel="icon" href="gemini.png" type="image/x-icon">
     <link rel="stylesheet" href="index.css">
     <!-- 可以通过link来导入index.css的样式，获得一样等同于style的效果 -->
     <style>
        /* 元素选择器 */
        /* 通配选择器 */
        *{
            /*   *代表全局的样式，但是这个选择器的优先级最低 */
            background-color: cornflowerblue;
        }
        h1{
            color: pink;
            background-color: aqua;
            /* 样式以;分隔 */
        }

        p{
            color: white;
        }
        /* 通过class的方式，类选择器的优先级比元素选择器更高 */
        .box1{
            /* 类名用.开头 */
            width:100px;
            height:100px;
            background-color: red;
        }
        .box2{
            width: 100px;
            height: 100px;
            background-color: white;
        }
        /* id选择器的id唯一，而class可以有多个 */
        #item1{
            width: 200px;
            height: 300px;
            background-color: green;
        /* id选择器的优先级是最高的 */
        }
        .box3{
            color:red;
        }
        .faker{
            color: blueviolet;
            background-color: rgb(65, 42, 73);
        }
        .zeus{
            color: red;
        }
        .gumayusi{
            color: blue;
        }

     </style>
</head>
<body>  
    <h1>元素选择器</h1>
    <div class="box1"></div>
    <div class="box2"></div>
     <div class="box1"></div>
     <!-- class的类可以有重复但是id不行 -->
    <!-- 类选择器 -->
     <p class="box3"></p>
     <div class="box1 box3" id="item1">真的是</div>
     <!-- class可以有多个类名，但是如果前面的类名和类名中有一样的属性，后面类名的属性会覆盖前面的类名属性 -->
    <div class="faker">
        <div class="zeus gumayusi">宙活</div>
        <!-- 如果有两个属性，后面的属性会覆盖前面的属性，gumayusi就覆盖了zeus -->
        <div class="oner">体育生</div>
        <!-- 子类只能继承父类的字体属性 -->
    </div>

     


   
</body>
</html>



<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>zofgk</title>
    <style>
        /* 交集选择器--必须同时拥有两个class */
        .faker.bengi{
            color: red;
        }
        div.zeus{
            /* 必须是div的同时有class属性 */
            color: blue;
        }
        /* 并集选择器--只要有一个元素 */
        .keria,.gumayusi{
            color:blanchedalmond;
        }
        .bang{
            color: blueviolet;
        }


    </style>
</head>
<body>
    <div class="faker bengi">交集选择器--必须同时拥有两个元素</div>
    
    <div class="zeus">咒活跪下</div>

    <div class="oner gumayusi">三连冠的体育生和他的鸡蛋</div>

    <div class="keria gumayusi">历史第一下路</div>

    <div class="gumayusi bang">但是后面的元素有属性会覆盖前面的属性</div>


    
</body>
</html>
